# DeepSeek 主分析模型
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_REASONING_EFFORT=max
DEEPSEEK_TIMEOUT_SECONDS=90
KEYWORD_GENERATION_TIMEOUT_SECONDS=45
DEEPSEEK_KEYWORD_MAX_TOKENS=800
DEEPSEEK_LINK_JUDGE_MAX_TOKENS=2048
DEEPSEEK_ANALYSIS_MAX_TOKENS=4000

# ── 运行环境 ──────────────────────────────────────
# development：本地开发，token 为空时自动跳过验证
# production：生产/外网访问，token 为空时拒绝启动
APP_ENV=development

# 本机前后端跨域（部署时增加 GitHub Pages 域名）
# 本地开发：http://localhost:5173,http://127.0.0.1:5173
# 外部访问：http://localhost:5173,http://127.0.0.1:5173,https://你的用户名.github.io
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── 访问令牌（安全关键） ──────────────────────────
# ⚠️ 生产/外网访问时必须设置强随机令牌！
# 前端用户在浏览器中输入此令牌后才能调用 API。
# 令牌仅保存在用户浏览器 localStorage，不经过 GitHub。
# 本地开发可留空（需 APP_ENV=development）。
# 生成示例：python -c "import secrets; print(secrets.token_urlsafe(32))"
APP_ACCESS_TOKEN=

# 输出目录
OUTPUT_DIR=outputs

# 当前暂不启用本地法律模型
USE_LAWFORMER=false
USE_DISC_LAWLLM=false
USE_INTERNLM_LAW=false

# 引用校验
STRICT_CITATION_MODE=true

# ── 在线索引检索 ──────────────────────────────────────
ONLINE_SEARCH_ENABLED=true
CASE_SEARCH_MODE=online_index
ONLINE_SEARCH_PROVIDER=tavily

# Tavily 搜索 API（推荐）
TAVILY_API_KEY=

# Google CSE（备选）
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# Bing（Legacy，不推荐作为默认 Provider。推荐使用 Tavily。）
BING_SEARCH_API_KEY=
BING_CUSTOM_CONFIG_ID=
BING_SEARCH_ENDPOINT=

# 自动检索参数
MAX_SEARCH_KEYWORDS_PER_GOAL=8
MAX_SEARCH_RESULTS_PER_KEYWORD=10
MAX_LINKS_TO_JUDGE=30
MAX_LINKS_TO_USE=8

# AI 链接判断性能优化
LINK_JUDGE_BATCH_SIZE=2
LINK_JUDGE_TIMEOUT_SECONDS=90
LINK_JUDGE_TOTAL_TIMEOUT_SECONDS=360
LINK_JUDGE_MAX_TITLE_CHARS=120
LINK_JUDGE_MAX_SNIPPET_CHARS=300
LINK_JUDGE_USE_PAGE_CONTENT=false
LINK_JUDGE_SKIP_PDF_CONTENT=true
LINK_JUDGE_QUICK_PASS_TOP_N=5
LINK_JUDGE_DEEP_PASS_TOP_N=3

# OCR 识别配置（扫描 PDF / 图片 → 文字）
# 推荐使用 PaddleOCR，中文识别效果好
# Windows CPU 安装：
#   pip install paddlepaddle -i https://www.paddlepaddle.org.cn/packages/stable/cpu/
#   pip install paddleocr pymupdf pillow
ENABLE_OCR=false
OCR_PROVIDER=paddleocr
OCR_LANGUAGE=ch
OCR_MAX_PAGES=20
OCR_DPI=200
OCR_SAVE_DEBUG_IMAGES=false
